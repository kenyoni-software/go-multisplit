{
	"name": "go-multisplit",
	"image": "mcr.microsoft.com/devcontainers/go:1.25",
	"customizations": {
		"vscode": {
			"settings": {
				"go.lintTool": "golangci-lint",
				"go.lintFlags": [
					"--path-mode=abs"
					//"--fast-only"
				],
				"go.formatTool": "custom",
				"go.alternateTools": {
					"golangci-lint": "custom-gcl",
					"customFormatter": "custom-gcl"
					// "customFormatter": "golangci-lint"
				},
				"go.formatFlags": [
					"fmt",
					"--stdin"
				],
				"gopls": {
					"formatting.gofumpt": false
				},
				"files.exclude": {
					"**/.git": true
				},
				"yaml.schemas": {
					"https://raw.githubusercontent.com/golangci/golangci-lint/refs/heads/main/jsonschema/custom-gcl.jsonschema.json": ".custom-gcl.yaml",
					"https://raw.githubusercontent.com/golangci/golangci-lint/refs/heads/main/jsonschema/golangci.jsonschema.json": ".golangci.yaml"
				}
			},
			"extensions": [
				"github.vscode-github-actions",
				"golang.go",
				"ms-azuretools.vscode-docker",
				"redhat.vscode-yaml"
			]
		}
	},
	"remoteUser": "vscode",
	"containerUser": "vscode",
	"postCreateCommand": "./.devcontainer/post-create.sh"
}